generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

// ==============================
// ENUMS (Strict State Management)
// ==============================

enum Role {
  ADMIN       // Full access
  CASHIER     // POS access
  KITCHEN     // KDS access only
}

enum OrderStatus {
  DRAFT       // Open order in POS
  PAID        // Successfully checked out
  CANCELLED   // Voided order
}

enum KdsStatus {
  PENDING     // Not sent to kitchen yet
  TO_COOK     // In KDS: Waiting to start
  PREPARING   // In KDS: Currently cooking
  COMPLETED   // In KDS: Ready to serve
}

enum PaymentType {
  CASH
  UPI
  CARD
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ==============================
// MODELS
// ==============================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String    // Hashed
  role          Role      @default(CASHIER)
  isArchived    Boolean   @default(false) // Soft delete
  
  // Relations
  sessions      Session[]
  ordersTaken   Order[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Customer {
  id            String    @id @default(cuid())
  name          String
  email         String?   @unique
  phone         String?   @unique
  
  // Relations
  orders        Order[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Category {
  id            String    @id @default(cuid())
  name          String    @unique
  color         String    @default("#E5E7EB")
  
  // Relations
  products      Product[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Product {
  id            String    @id @default(cuid())
  name          String
  description   String?
  price         Decimal   @db.Decimal(10, 2)
  uom           String    // Unit of measure (e.g., piece, kg)
  taxRate       Decimal   @default(0.00) @db.Decimal(5, 2)
  showInKds     Boolean   @default(true) // Filter for Kitchen Display
  isArchived    Boolean   @default(false)
  
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])
  
  orderItems    OrderItem[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Floor {
  id            String    @id @default(cuid())
  name          String
  
  tables        Table[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Table {
  id            String    @id @default(cuid())
  tableNumber   String
  seats         Int
  isActive      Boolean   @default(true)
  
  floorId       String
  floor         Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)
  
  orders        Order[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([floorId, tableNumber])
}

model Session {
  id            String    @id @default(cuid())
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  closingAmount Decimal?  @db.Decimal(10, 2)
  
  userId        String    // Cashier who opened it
  user          User      @relation(fields: [userId], references: [id])
  
  orders        Order[]
}

model PaymentMethod {
  id            String      @id @default(cuid())
  name          String
  type          PaymentType
  isEnabled     Boolean     @default(true)
  upiId         String?     // Nullable, only for UPI type
  
  payments      Payment[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Promotion {
  id              String        @id @default(cuid())
  name            String
  code            String?       @unique // Nullable if automated
  discountType    DiscountType
  discountValue   Decimal       @db.Decimal(10, 2)
  
  // Triggers
  minQuantity     Int?          // For Product-level promo
  minOrderAmount  Decimal?      @db.Decimal(10, 2) // For Order-level promo
  isActive        Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   Int         @unique @default(autoincrement())
  status        OrderStatus @default(DRAFT)
  
  subtotal      Decimal     @db.Decimal(10, 2)
  taxTotal      Decimal     @db.Decimal(10, 2)
  discountTotal Decimal     @default(0.00) @db.Decimal(10, 2)
  grandTotal    Decimal     @db.Decimal(10, 2)
  
  // Relations
  sessionId     String
  session       Session     @relation(fields: [sessionId], references: [id])
  
  userId        String      // Cashier
  user          User        @relation(fields: [userId], references: [id])
  
  tableId       String?
  table         Table?      @relation(fields: [tableId], references: [id])
  
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  
  items         OrderItem[]
  payments      Payment[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id            String      @id @default(cuid())
  quantity      Int
  unitPrice     Decimal     @db.Decimal(10, 2)
  lineTotal     Decimal     @db.Decimal(10, 2)
  notes         String?     // e.g., "No onions"
  
  kdsStatus     KdsStatus   @default(PENDING) // Granular kitchen tracking
  
  // Relations
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(10, 2)
  transactionRef String?      // Card auth code or UPI ref
  
  // Relations
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  methodId      String
  method        PaymentMethod @relation(fields: [methodId], references: [id])
  
  createdAt     DateTime      @default(now())
}
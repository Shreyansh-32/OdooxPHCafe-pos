generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// ENUMS
// ==============================

enum Role {
  ADMIN
  CASHIER
  KITCHEN
}

enum OrderStatus {
  DRAFT      // Active, being built
  SENT       // Sent to kitchen
  PAID       // Payment completed
  CANCELLED  // Voided
}

enum OrderSource {
  CASHIER   // Created by staff at POS
  CUSTOMER  // Created via QR table scan
}

enum KdsStatus {
  PENDING    // Just received
  TO_COOK    // Acknowledged by kitchen
  PREPARING  // Currently being made
  COMPLETED  // Ready to serve
}

enum PaymentType {
  CASH
  UPI
  CARD
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ==============================
// STAFF
// ==============================

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String    // bcrypt hash
  role       Role      @default(CASHIER)
  isArchived Boolean   @default(false) // Soft delete — never hard delete staff

  sessions   Session[]
  orders     Order[]
  auditLogs  AuditLog[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ==============================
// CUSTOMER
// ==============================

model Customer {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String    // bcrypt hash
  phone       String?
  isVerified  Boolean   @default(false)
  lastOrderAt DateTime?

  orders      Order[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==============================
// VENUE
// ==============================

model Floor {
  id        String   @id @default(cuid())
  name      String   // e.g., "Ground Floor", "Rooftop"
  sortOrder Int      @default(0)

  tables    Table[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id            String    @id @default(cuid())
  tableNumber   String    // e.g., "T1", "T2"
  seats         Int
  isActive      Boolean   @default(true)
  qrToken       String?   @unique  // Signed JWT — used as QR URL token
  qrGeneratedAt DateTime?

  floorId       String
  floor         Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)

  orders        Order[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([floorId, tableNumber])
}

// ==============================
// MENU
// ==============================

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("#E5E7EB")
  sortOrder Int       @default(0)
  isVisible Boolean   @default(true) // Toggle on customer menu

  products  Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String     @id @default(cuid())
  name        String
  description String?
  price       Decimal    @db.Decimal(10, 2)
  imageUrl    String?
  taxRate     Decimal    @default(0.00) @db.Decimal(5, 2)
  isAvailable Boolean    @default(true)   // Toggle out-of-stock
  showInKds   Boolean    @default(true)   // false = skip KDS (e.g., bottled water)
  isArchived  Boolean    @default(false)

  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])

  orderItems  OrderItem[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([categoryId, isArchived])
}

// ==============================
// POS SESSION
// ==============================

model Session {
  id            String    @id @default(cuid())
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  openingAmount Decimal   @db.Decimal(10, 2) // Cash in drawer at start
  closingAmount Decimal?  @db.Decimal(10, 2) // Cash counted at end

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  orders        Order[]
}

// ==============================
// PAYMENTS
// ==============================

model PaymentMethod {
  id        String      @id @default(cuid())
  name      String
  type      PaymentType
  isEnabled Boolean     @default(true)
  upiId     String?     // Café's UPI VPA for QR display (e.g., "cafeodoo@upi")

  payments  Payment[]

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Promotion {
  id             String       @id @default(cuid())
  name           String
  code           String?      @unique
  discountType   DiscountType
  discountValue  Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal?     @db.Decimal(10, 2)
  maxUses        Int?         // null = unlimited
  usedCount      Int          @default(0)
  validFrom      DateTime?
  validUntil     DateTime?
  isActive       Boolean      @default(true)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ==============================
// ORDERS
// ==============================

model Order {
  id            String      @id @default(cuid())
  orderNumber   Int         @unique @default(autoincrement())
  status        OrderStatus @default(DRAFT)
  source        OrderSource @default(CASHIER)
  customerNote  String?     // Special instructions for whole order

  subtotal      Decimal     @db.Decimal(10, 2)
  taxTotal      Decimal     @db.Decimal(10, 2)
  discountTotal Decimal     @default(0.00) @db.Decimal(10, 2)
  grandTotal    Decimal     @db.Decimal(10, 2)

  // Optional — null for customer QR orders
  sessionId     String?
  session       Session?    @relation(fields: [sessionId], references: [id])

  // Optional — null for customer self-orders
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])

  tableId       String?
  table         Table?      @relation(fields: [tableId], references: [id])

  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])

  promotionId   String?     // Denormalized for audit trail

  items         OrderItem[]
  payments      Payment[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([tableId, status])
  @@index([createdAt])
}

model OrderItem {
  id        String    @id @default(cuid())
  quantity  Int
  unitPrice Decimal   @db.Decimal(10, 2) // Snapshotted at order time
  lineTotal Decimal   @db.Decimal(10, 2) // quantity × unitPrice
  notes     String?   // e.g., "No sugar"
  kdsStatus KdsStatus @default(PENDING)

  orderId   String
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product   @relation(fields: [productId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([kdsStatus])
  @@index([orderId, kdsStatus])
}

model Payment {
  id             String        @id @default(cuid())
  amount         Decimal       @db.Decimal(10, 2)
  transactionRef String?       // Razorpay ID / UPI UTR / Card auth code
  notes          String?       // e.g., "Change given: ₹50"

  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  methodId       String
  method         PaymentMethod @relation(fields: [methodId], references: [id])

  createdAt      DateTime      @default(now())
}

// ==============================
// AUDIT & NOTIFICATIONS
// ==============================

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // ORDER_CREATED, PAYMENT_PROCESSED, QR_REGENERATED, etc.
  entity    String   // "Order", "Product", "Table"
  entityId  String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  meta      Json?    // Before/after state snapshot

  createdAt DateTime @default(now())
}

model Notification {
  id         String   @id @default(cuid())
  type       String   // NEW_ORDER, ORDER_READY, BILL_REQUESTED
  title      String
  message    String
  isRead     Boolean  @default(false)
  targetRole Role?    // Broadcast to all users of this role
  userId     String?  // Or direct to specific staff
  orderId    String?
  tableId    String?

  createdAt  DateTime @default(now())

  @@index([targetRole, isRead])
  @@index([userId, isRead])
}